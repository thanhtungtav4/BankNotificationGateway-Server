{
  "name": "bank-gateway/server",
  "description": "Laravel-oriented server scaffold for Bank Notification Gateway SaaS.",
  "type": "project",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^4.3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "audit": {
      "block-insecure": false
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^13.2",
    "mockery/mockery": "^1.6",
    "fakerphp/faker": "^1.24"
  }
}
